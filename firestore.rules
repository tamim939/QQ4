rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // In a real app, use a dedicated 'admins' collection.
      // For this app, we check specific emails or roles.
      return isSignedIn() && (
        request.auth.token.email == 'qq44@email.com' ||
        request.auth.token.email == 'rsjonayed07@gmail.com'
      );
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      // Initialize profile: Only yourself, limited fields
      allow create: if isSignedIn() && isOwner(userId) && 
        incoming().keys().hasAll(['displayName', 'mobile', 'wallet']) &&
        incoming().wallet == 0;
      
      // Update profile: Only yourself, logic to prevent direct wallet hacks
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatar', 'boundWallet']) &&
         incoming().wallet == existing().wallet)
      );
    }

    // -------------------------------------------------------------------------
    // TRANSACTIONS COLLECTION
    // -------------------------------------------------------------------------
    match /transactions/{txnId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      
      // Create request: status must be pending
      allow create: if isSignedIn() && isOwner(incoming().userId) &&
        incoming().status == 'pending' &&
        incoming().amount > 0 &&
        incoming().timestamp == request.time;
        
      // Admin actions: Approve/Reject
      allow update: if isAdmin() && 
        incoming().diff(existing()).affectedKeys().hasOnly(['status']) &&
        existing().status == 'pending';
        
      allow delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // BETS COLLECTION
    // -------------------------------------------------------------------------
    match /bets/{betId} {
      allow read: if isSignedIn() && isOwner(existing().userId);
      
      allow create: if isSignedIn() && isOwner(incoming().userId) &&
        incoming().amount >= 10 &&
        incoming().status == 'pending';
        
      // System update result
      allow update: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // GIFT CODES COLLECTION
    // -------------------------------------------------------------------------
    match /gift_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // GAME HISTORY
    // -------------------------------------------------------------------------
    match /game_periods/{duration}/history/{periodId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
