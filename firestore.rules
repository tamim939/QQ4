rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.displayName is string && data.displayName.size() <= 50 &&
               data.avatar is string && data.avatar.size() <= 500 &&
               data.userNumericId is string && data.userNumericId.size() <= 20;
      }

      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && (
        // Action: Profile Update (Settings)
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['displayName', 'avatar'])) ||
        // Action: Game / Rebate / Deposit Logic
        (request.resource.data.diff(resource.data).affectedKeys().hasAny(['wallet', 'totalWager', 'claimedRebate', 'hasDeposited', 'hideDepositBonus', 'lastBonusClaimDate']))
      ) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['uid', 'userNumericId', 'mobile']));
    }

    // --- Gift System ---
    match /gift_codes/{codeId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['currentClaims']);
    }

    match /gift_claims/{claimId} {
      allow read: if isOwner(resource.data.userId);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    // --- Game History ---
    // Specifically matching the segments to avoid ambiguity
    match /game_periods/{duration}/history/{periodId} {
      allow read: if true;
      allow create: if isSignedIn() && isValidId(periodId);
      allow update: if isSignedIn() && isValidId(periodId) && 
                      // Allow update only if it's a merge or providing some info, 
                      // in a real app this would be restricted to admin
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['number', 'color', 'size', 'periodId', 'timestamp']);
    }

    // --- Bets ---
    match /bets/{betId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidId(betId);
      allow update: if isOwner(resource.data.userId) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'payout']);
    }

    // --- Transactions ---
    match /transactions/{txId} {
      allow get: if isOwner(resource.data.userId);
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isSignedIn() && 
                      request.resource.data.userId == request.auth.uid &&
                      isValidId(txId);
      allow update: if isOwner(resource.data.userId) &&
                      request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status']);
    }
  }
}
