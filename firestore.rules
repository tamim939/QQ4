rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // -------------------------------------------------------------------------
    // GLOBAL HELPERS
    // -------------------------------------------------------------------------
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'qq44@email.com' ||
        request.auth.token.email == 'rsjonayed07@gmail.com'
      );
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // -------------------------------------------------------------------------
    // DEFAULT DENY
    // -------------------------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // -------------------------------------------------------------------------
    // USERS COLLECTION
    // -------------------------------------------------------------------------
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
      allow update: if isSignedIn() && (
        isAdmin() || 
        (isOwner(userId) && 
         incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'avatar', 'boundWallet']))
      );
    }

    // -------------------------------------------------------------------------
    // TRANSACTIONS COLLECTION
    // -------------------------------------------------------------------------
    match /transactions/{txnId} {
      allow read: if isSignedIn() && (isOwner(existing().userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow update, delete: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // BETS COLLECTION
    // -------------------------------------------------------------------------
    match /bets/{betId} {
      allow read: if isSignedIn() && isOwner(existing().userId);
      allow create: if isSignedIn() && isOwner(incoming().userId);
      allow update: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // GIFT CODES COLLECTION
    // -------------------------------------------------------------------------
    match /gift_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // -------------------------------------------------------------------------
    // GIFT CODES & CLAIMS
    // -------------------------------------------------------------------------
    match /gift_codes/{codeId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /claims/{claimUserId} {
        allow read: if isSignedIn() && (isOwner(claimUserId) || isAdmin());
        allow create: if isSignedIn() && isOwner(claimUserId);
      }
    }

    match /users/{userId}/gift_claims/{claimId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow create: if isSignedIn() && isOwner(userId);
    }

    // -------------------------------------------------------------------------
    // GAME HISTORY (Renamed duration to gameDuration to avoid reserved keyword)
    // -------------------------------------------------------------------------
    match /game_periods/{gameDuration}/history/{periodId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
