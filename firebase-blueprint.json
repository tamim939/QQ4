{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and wallet data",
      "type": "object",
      "properties": {
        "displayName": { "type": "string" },
        "mobile": { "type": "string" },
        "avatar": { "type": "string" },
        "wallet": { "type": "number" },
        "userNumericId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "boundWallet": {
          "type": "object",
          "properties": {
            "method": { "type": "string" },
            "number": { "type": "string" }
          }
        }
      },
      "required": ["displayName", "mobile", "wallet"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Deposit and withdrawal records",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw"] },
        "amount": { "type": "number" },
        "method": { "type": "string" },
        "txId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "success", "rejected"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "number": { "type": "string", "description": "For withdrawals" },
        "account": { "type": "string", "description": "Target account for deposits" }
      },
      "required": ["userId", "type", "amount", "status"]
    },
    "Bet": {
      "title": "Bet",
      "description": "Gaming bets",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["color", "size", "number"] },
        "value": { "type": "string" },
        "amount": { "type": "number" },
        "duration": { "type": "number" },
        "periodId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "win", "lose"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "GiftCode": {
       "title": "Gift Code",
       "description": "Gift codes for bonuses",
       "type": "object",
       "properties": {
          "code": { "type": "string" },
          "amount": { "type": "number" },
          "maxClaims": { "type": "number" },
          "currentClaims": { "type": "number" },
          "status": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
       }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profiles"
    },
    "transactions/{txnId}": {
      "schema": "Transaction",
      "description": "Payment records"
    },
    "bets/{betId}": {
      "schema": "Bet",
      "description": "User bets"
    },
    "gift_codes/{codeId}": {
       "schema": "GiftCode",
       "description": "Gift codes"
    },
    "game_periods/{duration}/history/{periodId}": {
       "schema": "object",
       "description": "Game results"
    }
  }
}
